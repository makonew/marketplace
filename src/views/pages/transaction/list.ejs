<h1>All Transactions</h1>
<a href="/transactions/new">Create New Transaction</a>
<% if (transactions.length > 0) { %>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Item</th>
                <th>Buyer</th>
                <th>Seller</th>
                <th>Price</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% transactions.forEach(t => { %>
                <tr>
                    <td><%= t.id %></td>
                    <td><%= t.item_name %></td>
                    <td><a href="/users/<%= t.buyer_id %>/purchases"><%= t.buyer_name %></a></td>
                    <td><a href="/users/<%= t.seller_id %>/sales"><%= t.seller_name %></a></td>
                    <td>$<%= t.price %></td>
                    <td><%= t.approved ? 'Approved' : 'Pending' %></td>
                    <td><%= t.created_at %></td>
                    <td>
                        <% if (!t.approved) { %>
                            <form action="/transactions/<%= t.id %>/approve" method="POST" style="display:inline;">
                                <input type="hidden" name="seller_id" value="<%= t.seller_id %>">
                                <button type="submit">Approve</button>
                            </form>
                        <% } else { %>
                            <form action="/transactions/<%= t.id %>/commit" method="POST" style="display:inline;">
                                <button type="submit">Commit</button>
                            </form>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
<% } else { %>
    <p>No transactions found</p>
<% } %>
<a href="/">Back to Home</a>