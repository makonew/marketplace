<form method="POST" action="/auth/register">
    <label for="login">
        Login
        <input type="text" name="login" id="login" required>
    </label>
    

    <label for="password">
        Hasło
        <input type="password" name="password" id="password" required>
    </label>

    <button type="submit">Zarejestruj</button>
</form>